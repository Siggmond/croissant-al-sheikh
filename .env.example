# Required for admin login
ADMIN_PASSWORD=change-this-long-password
AUTH_SECRET=change-this-random-32-byte-secret

# Required for production writes/reads with Vercel Edge Config storage
# Create an Edge Config in Vercel Storage, then add these values to Project Settings > Environment Variables.
EDGE_CONFIG_ID=ecfg_xxxxxxxxxxxxxxxxxxxxx
EDGE_CONFIG_READ_TOKEN=vercel_edge_config_read_token
VERCEL_API_TOKEN=vercel_rest_api_token_with_edge_config_access
EDGE_CONFIG_TEAM_ID=
EDGE_CONFIG_KEY=croissant_site_content

# Optional public settings
NEXT_PUBLIC_SITE_URL=https://your-domain.com
